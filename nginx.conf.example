# Nginx config untuk SPMB di Hostinger VPS
# Simpan di: /etc/nginx/sites-available/spmb
# Ganti "domain-kamu.com" dengan domain/subdomain yang kamu punya

server {
    listen 80;
    server_name domain-kamu.com www.domain-kamu.com;

    # Frontend React (static build)
    root /var/www/spmb-v2/frontend/dist;
    index index.html;

    # React Router - redirect semua ke index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API ke Node.js backend
    location /api/ {
        proxy_pass http://localhost:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # Akses folder uploads (foto jurusan, logo sekolah)
    location /uploads/ {
        alias /var/www/spmb-v2/backend/uploads/;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # Sembunyikan file sensitif
    location ~ /\. {
        deny all;
    }
}
