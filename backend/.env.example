# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database (pilih salah satu) ──────────────────────────────────────────────
# Opsi 1: Railway otomatis mengisi DATABASE_URL
DATABASE_URL=mysql://user:password@host:port/database

# Opsi 2: env var individual (untuk lokal / non-Railway)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=spmb_db
DB_SSL=false

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_string_random_panjang_minimal_32_karakter

# ── CORS (URL frontend yang diizinkan) ───────────────────────────────────────
# Jika frontend disajikan dari backend yang sama (Railway 1 service), kosongkan.
# Jika pakai domain terpisah: https://spmb-sekolah.vercel.app
FRONTEND_URL=https://domain-kamu.railwayapp.com

# ── Cloudinary (upload file) ─────────────────────────────────────────────────
# Daftar gratis di https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
